---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import AppCard from '../components/AppCard.astro';
import SearchFilter from '../components/SearchFilter.tsx';
import { apps } from '../lib/apps';
import { allCategories, categoryColorMap } from '../lib/categories';
import type { AppCategory } from '../lib/categories';

const categories = [...new Set(apps.map(a => a.category))] as AppCategory[];

const categoryTextColor: Record<string, string> = {
  green: 'text-notion-tag-green-text',
  orange: 'text-notion-tag-orange-text',
  purple: 'text-notion-tag-purple-text',
};

const categoryCounts: Record<string, number> = {};
for (const app of apps) {
  categoryCounts[app.category] = (categoryCounts[app.category] || 0) + 1;
}

// Stats for HeroSection
const totalApps = apps.length;
const totalAuthors = new Set(apps.flatMap(a => a.authors.map(au => au.githubId))).size;
const totalCategories = categories.length;
---
<BaseLayout title="우아한테크코스 앱 모음">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <HeroSection apps={apps} totalApps={totalApps} totalAuthors={totalAuthors} totalCategories={totalCategories} />

    <div class="flex flex-wrap items-center gap-3 mb-6">
      <span class="text-xs text-muted-foreground">카테고리:</span>
      {allCategories.map((cat) => (
        <a
          href={`/category/${cat}/`}
          class={`text-xs font-medium ${categoryTextColor[categoryColorMap[cat]]} hover:underline`}
        >
          {cat} ({categoryCounts[cat] || 0})
        </a>
      ))}
    </div>

    <div class="sticky top-0 z-10 bg-background pb-2 pt-4 -mx-6 px-6 border-b border-transparent" id="search-sticky">
      <SearchFilter client:load categories={categories} categoryCounts={categoryCounts} totalCount={apps.length} />
      <p id="app-count" class="text-xs text-muted-foreground mt-2">
        총 <strong class="text-foreground">{apps.length}</strong>개의 앱
      </p>
    </div>

    <div id="app-grid" class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-4">
      {apps.map((app) => (
        <AppCard
          id={app.id}
          name={app.name}
          emoji={app.emoji}
          category={app.category}
          reason={app.reason}
          authors={app.authors}
          prNumber={app.prNumber}
          url={app.url}
        />
      ))}
      <div id="no-results" class="text-center py-16 hidden col-span-full">
        <p class="text-muted-foreground text-sm">검색 결과가 없습니다.</p>
      </div>
    </div>

    <div id="load-more-wrap" class="mt-6 text-center">
      <button
        id="load-more-btn"
        class="px-6 py-2.5 rounded-lg border border-border text-sm font-medium text-foreground hover:bg-notion-hover transition-colors"
      >
        더 보기
      </button>
    </div>

    <div class="mt-12 rounded-lg border border-dashed border-border p-6 text-center">
      <p class="text-sm text-muted-foreground mb-2">
        나도 만든 앱을 등록하고 싶다면?
      </p>
      <a
        href="https://github.com/imakerjun/witty-web/issues/new?template=add-app.yml"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-foreground hover:opacity-70 transition-opacity"
      >
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        GitHub Issue로 요청하기
      </a>
    </div>
  </div>

  <button
    id="scroll-top"
    class="fixed bottom-6 right-6 w-10 h-10 rounded-full bg-primary text-primary-foreground shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-opacity z-20"
    aria-label="맨 위로"
  >
    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
  </button>
</BaseLayout>

<script>
  const btn = document.getElementById('scroll-top');
  if (btn) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 600) {
        btn.classList.remove('opacity-0', 'pointer-events-none');
        btn.classList.add('opacity-100');
      } else {
        btn.classList.add('opacity-0', 'pointer-events-none');
        btn.classList.remove('opacity-100');
      }
    }, { passive: true });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
