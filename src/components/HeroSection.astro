---
interface FeaturedApp {
  name: string;
  emoji: string;
  url: string;
  authors: { name: string; githubId: string }[];
  category: string;
}

interface Props {
  apps: FeaturedApp[];
  totalApps: number;
  totalAuthors: number;
  totalCategories: number;
}

const { apps, totalApps, totalAuthors, totalCategories } = Astro.props;

const shuffled = [...apps];
for (let i = shuffled.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
}
const featured = shuffled.slice(0, 3);

// Minimal data for client-side shuffle (name, emoji, url, authors summary, category)
const featuredPool = apps.map(a => ({
  n: a.name,
  e: a.emoji,
  u: a.url,
  a: a.authors.map(au => au.name).join(' · '),
  c: a.category,
}));
---
<section class="mb-12">
  <div class="rounded-xl bg-secondary/50 border border-border/50 p-6 md:p-8">
    <div class="mb-6">
      <h1 class="text-3xl font-bold tracking-tight text-foreground mb-2">
        우아한테크코스 앱 모음
      </h1>
      <p class="text-muted-foreground text-sm">
        크루들이 직접 만든 유용한 웹앱을 한곳에서 만나보세요.
      </p>
    </div>
    <div class="flex flex-wrap items-center gap-4 md:gap-6 mb-8">
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
        <span class="text-sm text-muted-foreground"><strong class="text-foreground">{totalApps}</strong>개의 앱</span>
      </div>
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span class="text-sm text-muted-foreground"><strong class="text-foreground">{totalAuthors}</strong>명의 크루</span>
      </div>
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>
        <span class="text-sm text-muted-foreground"><strong class="text-foreground">{totalCategories}</strong>개의 카테고리</span>
      </div>
    </div>
    <div class="flex items-center mb-4">
      <button
        id="shuffle-btn"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-medium text-muted-foreground hover:text-foreground hover:bg-background/80 border border-border/50 transition-colors"
      >
        <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
        다른 앱 추천받기
      </button>
    </div>
    <div id="featured-grid" class="grid grid-cols-1 md:grid-cols-3 gap-3">
      {featured.map((app) => (
        <a
          href={app.url}
          target="_blank"
          rel="noopener noreferrer"
          class="featured-card group flex items-center gap-3 rounded-lg border border-border/60 bg-background/60 p-4 transition-colors hover:bg-background"
        >
          <span class="text-2xl shrink-0 featured-emoji">{app.emoji}</span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-1.5">
              <span class="font-semibold text-sm text-foreground truncate featured-name">{app.name}</span>
              <svg class="w-3 h-3 text-muted-foreground opacity-0 group-hover:opacity-100 transition-opacity shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </div>
            <p class="text-xs text-muted-foreground truncate mt-0.5 featured-meta">
              {app.authors.map(a => a.name).join(' · ')} · {app.category}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script type="application/json" id="featured-pool" set:html={JSON.stringify(featuredPool)} />

<script>
  const poolEl = document.getElementById('featured-pool');
  const btn = document.getElementById('shuffle-btn');
  const grid = document.getElementById('featured-grid');

  if (poolEl && btn && grid) {
    const pool = JSON.parse(poolEl.textContent || '[]');

    btn.addEventListener('click', () => {
      // Fisher-Yates shuffle
      for (let i = pool.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [pool[i], pool[j]] = [pool[j], pool[i]];
      }
      const picks = pool.slice(0, 3);
      const cards = grid.querySelectorAll('.featured-card');
      cards.forEach((card, idx) => {
        const app = picks[idx];
        if (!app) return;
        card.setAttribute('href', app.u);
        card.querySelector('.featured-emoji').textContent = app.e;
        card.querySelector('.featured-name').textContent = app.n;
        card.querySelector('.featured-meta').textContent = app.a + ' · ' + app.c;
      });
    });
  }
</script>
